<style>/* widget: WordPress Menu */

/* reset defaults */
dd, dl, dt, li, ol, ul{
  border: unset;
  padding: unset;
  background: unset;
}
/* end reset defaults */

#uc_nav_menu_elementor_e4b5d16{
	position: relative;
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-mobile-wrapper{
 	display: flex;
}

#uc_nav_menu_elementor_e4b5d16 .ue-menu{
    display:flex;
    list-style:none;
    margin:0;
    position:relative;
  	justify-content:flex-end;
}

#uc_nav_menu_elementor_e4b5d16 a{
  	position: relative;
	text-decoration: none;
 	display: flex;
  	align-items: center;  
}

  #uc_nav_menu_elementor_e4b5d16 a:after,
  #uc_nav_menu_elementor_e4b5d16 a:before{
      content: "";
      z-index: 2;
      position:absolute;
  }

	






#uc_nav_menu_elementor_e4b5d16 .ue-menu > li {
	display: block;
  	       flex-shrink: 1;
   	   min-width: 0;
  	}

/* Simple multilevel dropdown */
#uc_nav_menu_elementor_e4b5d16 .ue-menu > li > .sub-menu {
	opacity: 0;
	visibility: hidden;
	position: absolute;
	list-style: none;
	text-align: inherit;
    display:block;
	z-index: 99;
}

/* First level appear */
#uc_nav_menu_elementor_e4b5d16 .ue-menu > li:hover > .sub-menu{
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_e4b5d16 .ue-menu > li.uc-active > .sub-menu {
	opacity: 1;
	visibility: visible;
}

/* Style for dropdown links */
#uc_nav_menu_elementor_e4b5d16 .ue-menu li > .sub-menu li {
	position: relative;
	display: block;
}

/* Second and third dropdown level */
#uc_nav_menu_elementor_e4b5d16 .ue-menu > li > .sub-menu li{
  display: block;
}

#uc_nav_menu_elementor_e4b5d16 .ue-menu > li > .sub-menu > li .sub-menu {
	opacity: 0;
	visibility: hidden;
	position: absolute;
	list-style: none;
	top:0px;
  	z-index: 100;
}

/* Second and third level appears */
#uc_nav_menu_elementor_e4b5d16 .ue-menu > li .sub-menu li:hover > .sub-menu {
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_e4b5d16 .ue-menu > li .sub-menu li.uc-active > .sub-menu {
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_e4b5d16 li,
#uc_nav_menu_elementor_e4b5d16 a{
	transition: all 0.3s ease-in-out;
}

#uc_nav_menu_elementor_e4b5d16 ul{
	transition: all 0.3s ease-in-out;
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-checkbox{ 
  	display: none; 
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-mobile{
  	display: none;
	transition: all .3s;
    cursor: pointer;
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-icon,
#uc_nav_menu_elementor_e4b5d16 .ue-back-link-icon{
	display: flex;
    transition: all .3s ease;
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-icon i {
  pointer-events: none;
}

#uc_nav_menu_elementor_e4b5d16 .ue-back-link{
  display: none !important;
}

#uc_nav_menu_elementor_e4b5d16 .uc-close-side-menu{
  display: none;
  transition: all .3s ease;
}

#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-mobile > *{
	display: none;
  	justify-content: center;
  	align-items: center;
}
#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-mobile > .uc-active{
	display: flex;
}

/* hover effects */
















/* end hover effects */


@media only screen and (max-width: 1024px) {
    
      #uc_nav_menu_elementor_e4b5d16 .ue-menu{
          justify-content:;
      }
      }

@media only screen and (max-width: 767px) {
    
  	 #uc_nav_menu_elementor_e4b5d16 .ue-menu{
          justify-content:inherit;
     }
     }


@media only screen and (max-width: 0px) {
  
	#uc_nav_menu_elementor_e4b5d16 .ue-menu {	
      	transition: all .3s;
      	flex-direction: column;      	
      	top: 100%;
      	left: 0;
      	z-index: 1000;
    }
  
    #uc_nav_menu_elementor_e4b5d16 .sub-menu{
      	visibility: visible !important;
      	opacity: 1 !important;
      	inset-inline-start: unset !important;
        transition-timing-function: ease;
    } 	

	#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-mobile {
        position: relative;
        display: flex;
        align-items:center;
        justify-content:center;      
	}

	#uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-checkbox:checked + .ue-menu {
		opacity: 1;
      	pointer-events: all;
	} 

    /* open sub menus from side */
          #uc_nav_menu_elementor_e4b5d16 .ue-menu{
        width: 100%;
        position: absolute;
        transform: translate(0, -20px);
     	opacity: 0; 
      	pointer-events: none;
      }

      #uc_nav_menu_elementor_e4b5d16 .ue-nav-menu-checkbox:checked + .ue-menu {
          transform: translate(0, px);
      } 
  
      #uc_nav_menu_elementor_e4b5d16 .ue-menu > li > .sub-menu {
          width: 100%;
          position:relative;
          top:auto;
      }

      #uc_nav_menu_elementor_e4b5d16 .ue-menu > li > .sub-menu > li .sub-menu {
          width: 100%;
          left: 0;
          z-index: 2;
          position:relative;
          top:auto;
      }
        /* end open sub menus from side */
  
}

</style>

